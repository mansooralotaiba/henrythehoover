# Henry The Hoover - environment variables template.
# Copy this file to .env and fill in real values for local dev.
# Production values live in Railway -> Variables (never commit .env).

# -- Anthropic --------------------------------------------------------
# Proxied through /api/claude. Never exposed to browser.
ANTHROPIC_API_KEY=sk-ant-...

# -- Discord webhooks -------------------------------------------------
# Server holds these. Browser never sees them.
DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_AUTO_WEBHOOK=https://discord.com/api/webhooks/...
# Periodic status embeds posted by the server every X minutes per active scan.
DISCORD_STATUS_WEBHOOK=https://discord.com/api/webhooks/...
# Live trade-journal embeds posted whenever a TP/SL/BE outcome is logged.
DISCORD_JOURNAL_WEBHOOK=https://discord.com/api/webhooks/...

# -- Supabase ---------------------------------------------------------
# Project Settings -> API. service_role key MUST stay server-side.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -- Site -------------------------------------------------------------
# Used for Supabase email-redirect targets. In Railway, set this to
# https://your-domain (or your custom domain).
SITE_URL=http://localhost:3000

# Railway sets PORT automatically; this is for local dev only.
PORT=3000

# -- Whop (PRIMARY subscriptions — card + crypto, native recurring) -----
# 1. Create a Whop product at whop.com → Dashboard → Products → New
#    Price $500/month, billing recurring monthly.
# 2. Copy the checkout URL (looks like https://whop.com/checkout/plan_XXXXXXXX/)
#    → WHOP_CHECKOUT_URL
# 3. Whop dashboard → Settings → API → create an API key → WHOP_API_KEY
# 4. Whop dashboard → Developers → Webhooks → New webhook
#    URL:  https://your-domain.com/api/whop/webhook
#    Events: membership.went_valid, membership.renewed,
#            membership.went_invalid, membership.cancel_at_period_end_changed
#    Copy the signing secret → WHOP_WEBHOOK_SECRET
WHOP_CHECKOUT_URL=
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=

# -- Paddle (FALLBACK card subscriptions, currently rejected our app) ---
# Leave blank to disable Paddle entirely.
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID=
PADDLE_ENV=production

# -- NowPayments (FALLBACK crypto, requires KYC on their side) ----------
# Leave blank to disable. Whop covers crypto already.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_PRICE_USD=500

# -- Admin -----------------------------------------------------------
ADMIN_EMAIL=mansoor.alotaiba@gmail.com

# -- Polygon / Massive (DXY + Gold market data) ----------------------
# Get your key at https://massive.com/dashboard/keys
POLYGON_API_KEY=

# -- Web Push (server pushes alerts to phone PWA) --------------------
# Generate ONCE locally:  node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is also exposed via /api/push/vapid-key for browser subscribe.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:noreply@henrythehoover.com
